# ─── Required: Spotify API Credentials ────────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard/applications
#
# 1. Log in → Create App → name it anything
# 2. Set redirect URI to: http://127.0.0.1:8888/callback
# 3. Copy Client ID below (no Client Secret needed — we use PKCE auth)

SPOTIFY_CLIENT_ID=
